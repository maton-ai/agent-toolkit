{
  "name": "@maton/agent-toolkit",
  "version": "0.1.0",
  "homepage": "https://github.com/maton-ai/agent-toolkit",
  "description": "Maton Agent Toolkit - connect popular agent frameworks (LangChain, Vercel AI SDK, OpenAI) to the Maton MCP server.",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf langchain ai-sdk modelcontextprotocol openai",
    "lint": "eslint \"./**/*.ts*\"",
    "prettier": "prettier './**/*.{js,ts,md,html,css}' --write",
    "prettier-check": "prettier './**/*.{js,ts,md,html,css}' --check",
    "test": "jest"
  },
  "exports": {
    "./langchain": {
      "types": "./langchain/index.d.ts",
      "require": "./langchain/index.js",
      "import": "./langchain/index.mjs"
    },
    "./ai-sdk": {
      "types": "./ai-sdk/index.d.ts",
      "require": "./ai-sdk/index.js",
      "import": "./ai-sdk/index.mjs"
    },
    "./openai": {
      "types": "./openai/index.d.ts",
      "require": "./openai/index.js",
      "import": "./openai/index.mjs"
    },
    "./modelcontextprotocol": {
      "types": "./modelcontextprotocol/index.d.ts",
      "require": "./modelcontextprotocol/index.js",
      "import": "./modelcontextprotocol/index.mjs"
    }
  },
  "packageManager": "pnpm@9.11.0",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maton-ai/agent-toolkit"
  },
  "author": "Maton <support@maton.ai> (https://maton.ai/)",
  "contributors": [
    "Richard Song <support@maton.ai>",
    "Byungkyu Park <support@maton.ai>"
  ],
  "license": "MIT",
  "keywords": [
    "maton",
    "agent",
    "toolkit",
    "mcp",
    "langchain",
    "ai-sdk",
    "openai"
  ],
  "devDependencies": {
    "@eslint/compat": "^1.2.4",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.10.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "peerDependencies": {
    "@langchain/core": "^1.2.1",
    "ai": "^7.0.18",
    "openai": "^6.45.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "files": [
    "ai-sdk/**/*",
    "langchain/**/*",
    "modelcontextprotocol/**/*",
    "openai/**/*",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "pnpm": {
    "overrides": {
      "esbuild@>=0.27.3 <0.28.1": "^0.28.1"
    }
  }
}
